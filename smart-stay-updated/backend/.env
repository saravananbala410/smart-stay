# ─── DATABASE ────────────────────────────────────────
# Local PostgreSQL (unna computer la install panna):
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/smartstay

# OR Supabase free cloud DB:
# DATABASE_URL=postgresql://postgres:yourpassword@db.xxxxx.supabase.co:5432/postgres

# ─── JWT SECRET ──────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ─── CLOUDINARY (Free file upload) ──────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAIL (Gmail SMTP for password reset) ───────────
SMTP_EMAIL=yourgmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# ─── FRONTEND URL ────────────────────────────────────
FRONTEND_URL=http://localhost:5173
